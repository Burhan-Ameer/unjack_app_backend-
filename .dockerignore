# Git
.git/
.gitignore

# Python cache / build artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/
*.egg-info/
.eggs/

# Local virtual envs
.venv/
venv/
env/
ENV/

# Local environment and secrets
.env
.env.*
!.env.example

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Runtime logs
*.log

# Tests and docs not required in runtime image
tests/
README.md
unjack-backend-plan.docx

# Keep Alembic migrations in build context
!alembic/
!alembic/versions/
!alembic/versions/*.py
